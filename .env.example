# Environment variables for VSDE
# Copy this file to .env and fill in the values

# ── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vsde

# ── LLM (multi-modal analysis) ─────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# ── Video input paths ───────────────────────────────────────────────
# Target: videos to be analyzed for visual style
TARGET_VIDEO_DIR=./data/raw/target

# Baseline: reference videos used as comparison baseline
BASELINE_VIDEO_DIR=./data/raw/baseline

# ── Output paths ────────────────────────────────────────────────────
# Extracted keyframes
FRAMES_DIR=./data/frames

# Embedding cache (safe to keep across runs)
CACHE_DIR=./data/cache

# LLM prompt output directory
PROMPT_OUTPUT_DIR=./data/output/prompts

# ── Model settings ──────────────────────────────────────────────────
EMBEDDING_DEVICE=cuda  # or 'cpu'
